generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Place {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  city        String
  country     String
  description String
  cuisines    String[]
  imageUrl    String
  priceLevel  String
  rating      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

